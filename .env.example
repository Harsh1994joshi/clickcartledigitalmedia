# ================================================================
# CLICK CARTEL — ENVIRONMENT VARIABLES
# ================================================================
# Copy this file to .env.local for local development
# Add these as Environment Variables in your Vercel dashboard
# ================================================================

# SMTP Configuration (Outlook / Microsoft)
# Use your Outlook email address as SMTP_USER
SMTP_USER=your-outlook-email@outlook.com

# SMTP Password:
#   - If you use a regular Outlook account: use your normal password
#   - If you have 2FA enabled on Microsoft: you MUST create an App Password:
#     1. Go to https://account.microsoft.com/security
#     2. Click "Advanced security options"
#     3. Under "App passwords", create a new app password
#     4. Use that generated password here (not your normal password)
SMTP_PASS=your-outlook-password-or-app-password

# The email address where form submissions will be delivered
# This is your receiving email
RECEIVER_EMAIL=developer2@knightmotion.com

# ================================================================
# HOW TO DEPLOY ON VERCEL:
# 1. Push your code to GitHub
# 2. Import repo on vercel.com
# 3. Go to Project Settings → Environment Variables
# 4. Add these 3 variables with your real values
# 5. Redeploy
# ================================================================
